FROM nginx:alpine

# Remove the default nginx welcome page config
RUN rm -f /etc/nginx/conf.d/default.conf

# Copy the generated nginx server block
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy static agent artifacts into nginx html root
# Requires: mcp.json and .well-known/agent.json produced by agentweld generate

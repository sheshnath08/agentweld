def build_crew(agent_dir: str | Path | None = None) -> Any:
    """Build and return a CrewAI Crew for {{ agent_name }}.

    Args:
        agent_dir: Path to the agent output directory containing ``mcp.json``
            and ``system_prompt.md``. Defaults to the directory containing this
            file's parent (i.e. the standard agentweld output directory).

    Returns:
        A ``Crew`` instance ready to ``kickoff()``.

    Raises:
        FileNotFoundError: If ``mcp.json`` is missing.
        ImportError: If ``crewai`` or ``crewai-tools[mcp]`` are not installed.
    """
    resolved: Path = Path(agent_dir) if agent_dir is not None else _AGENT_DIR

    if _USE_RUNTIME:
        loader = AgentWeldCrewLoader(agent_dir=resolved)
        return loader.build_crew(expose_tools=_EXPOSE_TOOLS)

    # ── Standalone path ───────────────────────────────────────────────────────
    try:
        from crewai import Agent, Crew, Task  # type: ignore[import-untyped]
        from crewai_tools import MCPServerAdapter  # type: ignore[import-untyped]
    except ImportError as exc:
        raise ImportError(
            "Install crewai with MCP support: "
            "pip install 'agentweld[loaders-crewai]'"
        ) from exc

    manifest = _load_mcp_manifest(resolved)
    system_prompt = _load_system_prompt(resolved)

    tools = []
    for _name, cfg in manifest.get("servers", {}).items():
        adapter = MCPServerAdapter(cfg)
        for tool in adapter.tools:
            if tool.name in _EXPOSE_TOOLS:
                tools.append(tool)

    agent = Agent(
        role="{{ agent_name }}",
        goal=system_prompt or "{{ agent_description }}",
        backstory="{{ agent_description }}",
        tools=tools,
    )
    task = Task(
        description="Execute the assigned task using available tools.",
        agent=agent,
        expected_output="Task completed.",
    )
    return Crew(agents=[agent], tasks=[task])



# Generated by agentweld {{ agentweld_version }} — do not edit manually.
# Regenerate with: agentweld generate --workspace
#
# Workspace-level compose — manages all agents with emit.deploy_config: true
#
# Bring up all agents:   docker compose up
# One agent only:        docker compose up {{ agents[0].slug if agents else "my-agent" }}
# Tail logs:             docker compose logs -f

services:
{% for agent in agents %}
  {{ agent.slug }}:
    build: ./agents/{{ agent.dir_name }}
    ports:
      - "{{ agent.port }}:80"
    env_file: ./agents/{{ agent.dir_name }}/.env
    restart: unless-stopped
{% endfor %}

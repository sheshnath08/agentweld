# Generated by agentweld {{ agentweld_version }}
# Serves two A2A discovery routes for {{ agent_name }}

server {
    listen 80;
    server_name _;

    location = /mcp.json {
        root /usr/share/nginx/html;
        default_type application/json;
        add_header Cache-Control "no-cache";
    }

    location = /.well-known/agent.json {
        alias /usr/share/nginx/html/.well-known/agent.json;
        default_type application/json;
        add_header Cache-Control "no-cache";
    }

    location / {
        return 404;
    }
}
